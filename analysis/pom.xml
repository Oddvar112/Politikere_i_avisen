			<groupId>org.apache.opennlp</groupId>
			<artifactId>opennlp-models-tokenizer-no</artifactId>
			<version>1.2.0</version>
		</dependency>
		<dependency>
			<groupId>org.apache.opennlp</groupId>
			<artifactId>opennlp-models-sentdetect-no</artifactId>
			<version>1.2.0</version>
		</dependency>
